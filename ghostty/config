# Ghostty config
# Reference: https://ghostty.org/docs/config/reference
# Reload in-app with: ctrl+shift+, (or quit + relaunch)

# --- Quick terminal (drop-down on cmd+`) ---
# global: prefix is required for the binding to fire when Ghostty isn't focused.
# First use will prompt for the macOS accessibility permission.
keybind = global:cmd+grave_accent=toggle_quick_terminal
quick-terminal-position = bottom
quick-terminal-animation-duration = 0.15
quick-terminal-screen = main


background-opacity = 0.90
# background-blur-radius = 20    # macOS only; nice with transparency, costs a little GPU

# --- Sensible defaults to add later (uncomment as you decide) ---
# font-family = "JetBrains Mono"
# font-size = 13
# theme = GruvboxDark
# cursor-style = block
# cursor-style-blink = false

# Ghostty already defaults scrollback to 10,000 lines (your iTerm was at 1,000).
# scrollback-limit = 100000
